{
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "tailwindFunctions": ["tv"],
  "importOrder": [
    "^(react/(.*)$)|^(react$)",
    "^(next/(.*)$)|^(next$)",
    "",
    "<THIRD_PARTY_MODULES>",
    "",
    "^auth.config$",
    "^models/(.*)$",
    "^types/(.*)$",
    "^enums/(.*)$",
    "^consts$",
    "^consts/(.*)$",
    "^helpers/(.*)$",
    "^hooks/(.*)$",
    "^api/(.*)$",
    "^context/(.*)$",
    "^stores/(.*)$",
    "^components/ui/(.*)$",
    "^components/(.*)$",
    "^public/(.*)$",
    "^styles/(.*)$",
    "^app/(.*)$",
    "",
    "^[./]"
  ]
}
